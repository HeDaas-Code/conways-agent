# Obsidian Agent 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==========================================
# 必需配置
# ==========================================

# Obsidian Vault 路径（Agent 的"身体"）
# 设置为你 Obsidian 库的根目录
OBSIDIAN_VAULT_PATH=/path/to/your/vault

# ==========================================
# LLM 配置
# ==========================================

# MiniMax CN Token Plan（推荐）：使用 Anthropic-compatible 端点
# 支持 MiniMax M2.7 / M2.5 / M2.1 等模型
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=your-token-plan-key
LITELLM_MODEL=anthropic/MiniMax-M2.7

# OpenAI:
# OPENAI_API_KEY=sk-...
# LITELLM_MODEL=gpt-4

# Anthropic（原生）:
# ANTHROPIC_API_KEY=sk-ant-...
# LITELLM_MODEL=claude-3-opus-20240229

# ==========================================
# 可选配置
# ==========================================

# 日志级别: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# 服务器端口（默认 8000）
# SERVER_PORT=8000

# 睡眠/唤醒周期（秒）
# WAKE_DURATION=300
# SLEEP_DURATION=900

# Agent 名称
# AGENT_NAME=图书馆居者
