# Obsidian Agent 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==========================================
# 必需配置
# ==========================================

# Obsidian Vault 路径（Agent 的"身体"）
# 设置为你 Obsidian 库的根目录
OBSIDIAN_VAULT_PATH=/path/to/your/vault

# ==========================================
# LLM 配置（LiteLLM）
# ==========================================

# 默认模型。如果不设置，默认为 minimax-cn/gemini-2.5-flash
# LITELLM_MODEL=minimax-cn/gemini-2.5-flash

# LiteLLM API 密钥（根据你的模型提供商设置）
# OpenAI:
# OPENAI_API_KEY=sk-...

# Anthropic:
# ANTHROPIC_API_KEY=sk-ant-...

# 通用的 LiteLLM API Key（某些代理服务需要）:
# LITELLM_API_KEY=your-api-key

# LiteLLM 代理地址（如果使用代理服务）:
# LITELLM_API_BASE=https://your-proxy.com

# ==========================================
# 可选配置
# ==========================================

# 日志级别: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# 服务器端口（默认 8000）
# SERVER_PORT=8000

# 睡眠/唤醒周期（秒）
# WAKE_DURATION=300
# SLEEP_DURATION=900

# Agent 名称
# AGENT_NAME=图书馆居者
